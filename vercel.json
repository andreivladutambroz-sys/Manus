{
  "buildCommand": "pnpm build",
  "devCommand": "pnpm dev",
  "installCommand": "pnpm install",
  "framework": "vite",
  "outputDirectory": "dist",
  "regions": ["iad1"],
  "env": {
    "DATABASE_URL": "MySQL/TiDB connection string",
    "KIMI_API_KEY": "Kimi AI API key for diagnostics",
    "SUPABASE_URL": "Supabase project URL",
    "SUPABASE_SERVICE_ROLE_KEY": "Supabase service role key for data imports",
    "SUPABASE_ANON_KEY": "Supabase anonymous key for client",
    "JWT_SECRET": "JWT secret for session management",
    "VITE_APP_ID": "Manus OAuth app ID",
    "OAUTH_SERVER_URL": "Manus OAuth server URL",
    "VITE_OAUTH_PORTAL_URL": "Manus OAuth portal URL",
    "BUILT_IN_FORGE_API_URL": "Manus Forge API URL",
    "BUILT_IN_FORGE_API_KEY": "Manus Forge API key",
    "VITE_FRONTEND_FORGE_API_URL": "Frontend Forge API URL",
    "VITE_FRONTEND_FORGE_API_KEY": "Frontend Forge API key",
    "FLARESOLVERR_API": "FlareSolverr API endpoint",
    "CRON_SECRET": "Secret for cron job authentication"
  },
  "crons": [
    {
      "path": "/api/cron/collect-data",
      "schedule": "0 2 * * *"
    }
  ],
  "functions": {
    "api/**": {
      "maxDuration": 60,
      "memory": 3008
    }
  }
}
