# ============================================================================
# Product-Orchestrator Environment Variables
# ============================================================================
# Copy this file to .env.orchestrator and fill in your values
# DO NOT commit .env.orchestrator to git (add to .gitignore)
# ============================================================================

# ============================================================================
# PostgreSQL (Knowledge Base)
# ============================================================================
POSTGRES_USER=kb_user
POSTGRES_PASSWORD=CHANGE_ME_SECURE_PASSWORD_HERE
POSTGRES_DB=mechanic_kb
POSTGRES_PORT=5432

# If using managed PostgreSQL (Supabase, RDS, etc.):
# POSTGRES_URL=postgresql://user:password@host:5432/database

# ============================================================================
# Redis (Rate Limiting + Job Queue)
# ============================================================================
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_PORT=6379

# If using managed Redis (AWS ElastiCache, etc.):
# REDIS_URL=redis://:password@host:6379

# ============================================================================
# MySQL (Existing App Database - DO NOT CHANGE)
# ============================================================================
DATABASE_URL=mysql://user:password@host:3306/database

# ============================================================================
# API Keys (Required)
# ============================================================================

# OpenAI API Key (for embeddings)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-CHANGE_ME_OPENAI_KEY

# Kimi API Key (for orchestrator)
# Get from: https://platform.moonshot.cn/console/api-keys
KIMI_API_KEY=sk-CHANGE_ME_KIMI_KEY

# ============================================================================
# Kimi API Configuration
# ============================================================================
KIMI_API_URL=https://api.moonshot.ai/v1
KIMI_MODEL=moonshot-v1-8k

# ============================================================================
# Rate Limiting
# ============================================================================
# Global Kimi API rate limit: 5 requests per minute
RATE_LIMIT_MAX_REQUESTS=5
RATE_LIMIT_WINDOW_MS=60000

# ============================================================================
# Ports
# ============================================================================
ORCHESTRATOR_API_PORT=3001
POSTGRES_PORT=5432
REDIS_PORT=6379
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# ============================================================================
# Grafana
# ============================================================================
GRAFANA_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD

# ============================================================================
# Logging
# ============================================================================
LOG_LEVEL=info
# Options: debug, info, warn, error

# ============================================================================
# Ingestion Worker
# ============================================================================
JSONL_DIRECTORY=/app/knowledge-base
POLL_INTERVAL_MS=5000
BATCH_SIZE=100
MAX_CONCURRENT_BATCHES=3

# ============================================================================
# Node.js
# ============================================================================
NODE_ENV=production
# Options: development, production

# ============================================================================
# Optional: Monitoring
# ============================================================================
# Enable Prometheus metrics
ENABLE_PROMETHEUS=true

# Enable Grafana dashboards
ENABLE_GRAFANA=true

# ============================================================================
# Optional: Advanced Configuration
# ============================================================================

# PostgreSQL connection pool size
POSTGRES_POOL_SIZE=10

# Redis connection timeout
REDIS_CONNECT_TIMEOUT=5000

# API request timeout
API_REQUEST_TIMEOUT=30000

# Vector search similarity threshold (0.0 - 1.0)
VECTOR_SIMILARITY_THRESHOLD=0.5

# Maximum vector search results
VECTOR_SEARCH_LIMIT=5

# ============================================================================
# IMPORTANT SECURITY NOTES
# ============================================================================
# 1. Change all CHANGE_ME_* values before deploying to production
# 2. Use strong passwords (min 32 characters with mixed case, numbers, symbols)
# 3. Never commit .env.orchestrator to git
# 4. Rotate API keys regularly
# 5. Use managed services (Supabase, AWS) for production databases
# 6. Enable SSL/TLS for all connections
# 7. Use secrets management (AWS Secrets Manager, Vault, etc.)
# ============================================================================
